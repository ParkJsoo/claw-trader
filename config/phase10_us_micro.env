# Phase 10 US Micro Trading Config (IBKR)
# 적용: app/runner.py 재기동 시 반영 (동적 reload 아님)
# 사용: set -a && source .env && source config/phase10_us_micro.env && set +a

# StrategyEngine — US
STRATEGY_US_COOLDOWN_SEC=300       # 동일 종목 재진입 쿨다운 5분
STRATEGY_US_DAILY_CAP=20           # 일 최대 신호 수

# RiskEngine — US
RISK_US_MAX_CONCURRENT=2           # 최대 동시 포지션
RISK_US_DAILY_LOSS_LIMIT=-200      # 일 손실 한도 (USD)
RISK_US_ALLOCATION_CAP_PCT=0.30    # 잔고 30%

# US watchlist
GEN_WATCHLIST_US=AAPL,NVDA,MSFT,TSLA,META,GOOGL,AMZN,AMD

# position_exit_runner — US 자동 매도
EXIT_STOP_LOSS_PCT=0.02            # 손절 -2%
EXIT_TAKE_PROFIT_PCT=0.02          # 익절 +2%
EXIT_TIME_LIMIT_SEC=3600           # 최대 보유 1시간 (KR 30분보다 길게)
