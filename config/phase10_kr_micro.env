# Phase 10/11 KR Micro Trading Config
# 적용: app/runner.py 재기동 시 반영 (동적 reload 아님)
# 사용: set -a && source .env && source config/phase10_kr_micro.env && set +a

# StrategyEngine — KR
STRATEGY_KR_COOLDOWN_SEC=300       # Phase 11: 10분(600s) → 5분(300s) (단타 최적화)
STRATEGY_KR_DAILY_CAP=40           # 일 최대 신호 수

# RiskEngine — KR
RISK_KR_MAX_CONCURRENT=2           # 최대 동시 포지션
RISK_KR_DAILY_LOSS_LIMIT=-500000   # 일 손실 한도 (KRW)
RISK_KR_ALLOCATION_CAP_PCT=1.00    # 잔고 전액 사용 허용

# AISignalGenerator — 일일 호출 캡
GEN_DAILY_CALL_CAP=1500            # AI 호출 일일 한도 (signal_generator_runner)

# ai_dual_eval_runner — AI call 최적화 (Issue 3: 1500/day → ~900/day 목표)
DUAL_POLL_SEC=180                  # 2분 → 3분 (30% call 절감)
DUAL_DAILY_CALL_CAP=500            # 시장별 일일 캡 (KR+US 합산 ~900)

# consensus_signal_runner — Phase 11
CONSENSUS_POLL_SEC=60              # Phase 11: 30초 → 60초 (중복 emit 감소)
CONSENSUS_SYMBOL_COOLDOWN_SEC=180  # Phase 11: 동일 종목 3분 내 재emit 차단
CONSENSUS_MIN_RET_5M=0.001         # Phase 11: ret_5m threshold 강화 (0.0 → 0.001)

# watchlist_selector — 동적 워치리스트
GEN_UNIVERSE_KR=005930,105560,055550,086790,034020,010950,035720,032640,000660,051910,035420,068270,006400,028260,096770,003550,017670,030200,009830,011200,004020,000080,034220,047050,010620,012330,032830,079550,010140,011170
UNIVERSE_SELECT_COUNT=8

# order_watcher — KR 주문 TTL (Phase 12: 15s → 60s, KIS limit order 체결 대기)
WATCHER_TTL_CANCEL_SEC=60

# position_exit_runner — Phase 12 자동 매도
EXIT_POLL_SEC=30                   # 포지션 동기화 + exit 체크 주기
EXIT_STOP_LOSS_PCT=0.02            # 손절 -2%
EXIT_TAKE_PROFIT_PCT=0.02          # 익절 +2%
EXIT_TIME_LIMIT_SEC=3600           # 최대 보유 60분

WATCHLIST_KR_MAX_PRICE=50000     # 최대 매수 가능 가격 (원) — 잔고/max_concurrent 기준
