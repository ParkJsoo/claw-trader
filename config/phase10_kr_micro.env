# Phase 10 KR Micro Trading Config
# 적용: app/runner.py 재기동 시 반영 (동적 reload 아님)
# 사용: source config/phase10_kr_micro.env && PYTHONPATH=src venv/bin/python -m app.runner

# StrategyEngine — KR
STRATEGY_KR_COOLDOWN_SEC=600       # 10분 쿨다운 (기본값 300s → Phase 10: 600s)
STRATEGY_KR_DAILY_CAP=40           # 일 최대 신호 수 (Day 1: 20 → Day 2: 40)

# RiskEngine — KR
RISK_KR_MAX_CONCURRENT=2           # 최대 동시 포지션 (기본값 5 → Phase 10: 2)
RISK_KR_DAILY_LOSS_LIMIT=-500000   # 일 손실 한도 (KRW, 기본값 유지)

# AISignalGenerator — 일일 호출 캡
GEN_DAILY_CALL_CAP=1500            # AI 호출 일일 한도 (Day 1: 1000 → Day 2: 1500)
