# Phase 10/11 KR Micro Trading Config
# 적용: app/runner.py 재기동 시 반영 (동적 reload 아님)
# 사용: set -a && source .env && source config/phase10_kr_micro.env && set +a

# StrategyEngine — KR
STRATEGY_KR_COOLDOWN_SEC=300       # Phase 11: 10분(600s) → 5분(300s) (단타 최적화)
STRATEGY_KR_DAILY_CAP=40           # 일 최대 신호 수

# RiskEngine — KR
RISK_KR_MAX_CONCURRENT=3           # 최대 동시 포지션
RISK_KR_DAILY_LOSS_LIMIT=-500000   # 일 손실 한도 (KRW)
RISK_KR_ALLOCATION_CAP_PCT=1.00    # 잔고 전액 사용 허용

# AISignalGenerator — 일일 호출 캡
GEN_DAILY_CALL_CAP=1500            # AI 호출 일일 한도 (signal_generator_runner)

# ai_dual_eval_runner — AI call 최적화 (Issue 3: 1500/day → ~900/day 목표)
DUAL_POLL_SEC=60                   # momentum: 60초 (급등 빠른 감지)
DUAL_DAILY_CALL_CAP=5000           # 시장별 일일 캡 (COIN 24/7 대응 확대)

# consensus_signal_runner — momentum breakout
CONSENSUS_POLL_SEC=30              # 30초 폴링 (급등은 빠르게 감지해야 함)
CONSENSUS_SYMBOL_COOLDOWN_SEC=300  # 동일 종목 5분 내 재emit 차단
MB_MIN_SURGE_5M=0.010              # 5분 급등 최소 기준 1.0%
UPBIT_WATCHLIST_COUNT=20           # COIN 워치리스트 20개
UPBIT_MIN_VOL_KRW=5000000000      # 최소 거래대금 50억 (100억 → 50억, 후보 확대)
UPBIT_WATCHLIST_INTERVAL_SEC=600        # 워치리스트 갱신 주기 10분 (1시간 → 10분)
UPBIT_SURGE_RATE=0.05                   # 당일 5% 이상 급등 시 워치리스트 편입
UPBIT_SURGE_MIN_VOL_KRW=1000000000      # 급등 편입 최소 거래대금 10억
UPBIT_SURGE_MAX_ADD=10                  # 급등 편입 최대 종목 수

# watchlist_selector — 동적 워치리스트
GEN_UNIVERSE_KR=005930,105560,055550,086790,034020,010950,035720,032640,000660,051910,035420,068270,006400,028260,096770,003550,017670,030200,009830,011200,004020,000080,034220,047050,010620,012330,032830,079550,010140,011170
WATCHLIST_SELECT_INTERVAL_MARKET_SEC=1800   # 장중 갱신 주기 30분 (1시간 → 30분)
WATCHLIST_DYNAMIC_VOLUME_TOP_N=50           # 거래량 상위 N개 (30 → 50)
WATCHLIST_DYNAMIC_FLUCT_TOP_N=50            # 등락률 상위 N개 (30 → 50)
WATCHLIST_DYNAMIC_MIN_VOL=100000            # 최소 거래량 10만 (50만 → 10만)
UNIVERSE_SELECT_COUNT=12

# order_watcher — KR 주문 TTL (Phase 12: 15s → 60s, KIS limit order 체결 대기)
WATCHER_TTL_CANCEL_SEC=60

# position_exit_runner — momentum breakout 자동 매도
EXIT_POLL_SEC=30                   # 포지션 동기화 + exit 체크 주기
EXIT_STOP_LOSS_PCT=0.025           # 손절 -2.5% (모멘텀 여유폭)
EXIT_TAKE_PROFIT_PCT=0.05          # 익절 +5.0%
EXIT_TIME_LIMIT_SEC=900            # 최대 보유 15분 (모멘텀 페이드)
EXIT_TRAIL_STOP_PCT=0.020          # trailing stop: 고점 대비 -2.0%
EXIT_TIME_LIMIT_MAX_SEC=3600       # time_limit 연장 최대 1시간 (수익 중일 때)

WATCHLIST_KR_MAX_PRICE=50000     # 최대 매수 가능 가격 (원) — 잔고/max_concurrent 기준
