# Phase 10/11 KR Micro Trading Config
# 적용: app/runner.py 재기동 시 반영 (동적 reload 아님)
# 사용: set -a && source .env && source config/phase10_kr_micro.env && set +a

# StrategyEngine — KR
STRATEGY_KR_COOLDOWN_SEC=300       # Phase 11: 10분(600s) → 5분(300s) (단타 최적화)
STRATEGY_KR_DAILY_CAP=15           # 일 최대 신호 수 (40 → 15, 품질 우선)

# RiskEngine — KR
RISK_KR_MAX_CONCURRENT=3           # 최대 동시 포지션
RISK_KR_DAILY_LOSS_LIMIT=-500000   # 일 손실 한도 (KRW)
RISK_KR_ALLOCATION_CAP_PCT=1.00    # 잔고 전액 사용 허용

# AISignalGenerator — 일일 호출 캡
GEN_DAILY_CALL_CAP=1500            # AI 호출 일일 한도 (signal_generator_runner)

# ai_dual_eval_runner — AI call 최적화 (Issue 3: 1500/day → ~900/day 목표)
DUAL_POLL_SEC=60                   # momentum: 60초 (급등 빠른 감지)
DUAL_DAILY_CALL_CAP=5000           # 시장별 일일 캡 (COIN 24/7 대응 확대)

# consensus_signal_runner — momentum breakout
CONSENSUS_POLL_SEC=30              # 30초 폴링 (급등은 빠르게 감지해야 함)
CONSENSUS_SYMBOL_COOLDOWN_SEC=300  # 동일 종목 5분 내 재emit 차단
MB_MIN_SURGE_5M=0.020              # legacy fallback (COIN/US 공용)
MB_MIN_SURGE_5M_COIN=0.003         # COIN 5분 급등 최소 기준 0.3% (pause 상태 shadow/coverage 확보용)
MB_MIN_SURGE_5M_US=0.020           # US 5분 급등 최소 기준 2.0%
MB_MIN_SURGE_5M_KR=0.015          # KR 5분 급등 최소 기준 1.5% (runtime truth)
MB_MIN_RET_1M=0.002                # 기본 1분 모멘텀 하한
MB_MIN_RET_1M_COIN=0.004           # COIN 1분 모멘텀 하한 0.4% (late-entry/flat momentum 차단)
COIN_MIN_RET1M_TO_RET5M_RATIO=0.35 # COIN 1분/5분 가속 비율 최소값
CONSENSUS_VOLUME_SURGE_RATIO=1.5   # COIN/US 거래량 surge 최소 배수
CONSENSUS_VOLUME_SURGE_RATIO_KR=1.2 # KR 거래량 surge 최소 배수
CONSENSUS_VOLUME_SURGE_MIN_SAMPLES=3
CONSENSUS_VOLUME_SURGE_MIN_SAMPLES_KR=0
MB_MAX_SURGE_5M=0.035              # 5분 급등 상한 3.5% (꼭지 매수 방지 — 후발 진입 차단)
COIN_REGIME_BEARISH_THRESHOLD=0.45 # bearish 감지 임계치 (0.6 → 0.45, 빠른 하락장 감지)
UPBIT_WATCHLIST_COUNT=30           # COIN 워치리스트 30개 (G 같은 대형 무버 편입)
UPBIT_MIN_VOL_KRW=5000000000      # 최소 거래대금 50억 (100억 → 50억, 후보 확대)
UPBIT_WATCHLIST_INTERVAL_SEC=600        # 워치리스트 갱신 주기 10분 (1시간 → 10분)
UPBIT_SURGE_RATE=0.05                   # 당일 5% 이상 급등 시 워치리스트 편입
UPBIT_SURGE_MIN_VOL_KRW=1000000000      # 급등 편입 최소 거래대금 10억
UPBIT_SURGE_MAX_ADD=10                  # 급등 편입 최대 종목 수

# watchlist_selector — 동적 워치리스트
GEN_UNIVERSE_KR=005930,105560,055550,086790,034020,010950,035720,032640,000660,051910,035420,068270,006400,028260,096770,003550,017670,030200,009830,011200,004020,000080,034220,047050,010620,012330,032830,079550,010140,011170
WATCHLIST_SELECT_INTERVAL_MARKET_SEC=1800   # 장중 갱신 주기 30분 (1시간 → 30분)
WATCHLIST_DYNAMIC_VOLUME_TOP_N=50           # 거래량 상위 N개 (30 → 50)
WATCHLIST_DYNAMIC_FLUCT_TOP_N=50            # 등락률 상위 N개 (30 → 50)
WATCHLIST_DYNAMIC_MIN_VOL=100000            # 최소 거래량 10만 (50만 → 10만)
UNIVERSE_SELECT_COUNT=12

# order_watcher — KR 주문 TTL (Phase 12: 15s → 60s, KIS limit order 체결 대기)
WATCHER_TTL_CANCEL_SEC=60

# position_exit_runner — momentum breakout 자동 매도
EXIT_POLL_SEC=30                   # 포지션 동기화 + exit 체크 주기
EXIT_STOP_LOSS_PCT=0.015           # 손절 -1.5% (KR scalp 재조정)
EXIT_TAKE_PROFIT_PCT=0.030         # 익절 +3.0% (KR scalp 재조정)
EXIT_TIME_LIMIT_SEC=900            # 최대 보유 15분 (KR scalp)
EXIT_TRAIL_STOP_PCT=0.015          # trailing stop: 고점 대비 -1.5% (KR)
EXIT_TIME_LIMIT_MAX_SEC=3600       # time_limit 연장 최대 1시간 (KR)
KR_TRAIL_ONLY_TRIGGER_PCT=0.020    # +2.0% 도달 후 take_profit 대신 trailing 우선

# COIN Big Mover Ride — KR scalp과 분리, trailing stop으로 대형 상승 포착
COIN_EXIT_TAKE_PROFIT_PCT=0.15     # 익절 +15% (20% → 15%, Redis override 30% 유지 가능)
COIN_EXIT_STOP_LOSS_PCT=0.030      # 손절 -3.0% (4% → 3%, early_exit과 이중손절 충돌 해소 — 단일화)
COIN_EXIT_TRAIL_STOP_PCT=0.040     # trailing stop: 고점 대비 -4.0% (5% → 4%, 기본 trail)
COIN_EXIT_TRAIL_STOP_TIGHT_PCT=0.030  # 2단계: +5% 달성 후 tight trail -3.0% (이익 보호)
COIN_EXIT_TRAIL_TIGHT_TRIGGER=0.050   # tight trail 발동 기준 (HWM이 avg +5% 달성 시)
COIN_EXIT_TIME_LIMIT_SEC=3600      # 최대 보유 1시간 (기본)
COIN_EXIT_TIME_LIMIT_MAX_SEC=14400 # 수익 중 최대 4시간 (추세 지속 시)
COIN_EARLY_EXIT_SEC=600            # 조기청산 기준: 10분 경과
COIN_EARLY_EXIT_PCT=0.010          # 조기청산 손실 기준: -1.0%
COIN_TYPE_A_MODE=live              # COIN type_a 운영 모드: live/shadow/off
COIN_TYPE_B_MODE=live              # COIN type_b 운영 모드: live/shadow/off
TYPE_B_MAX_CHANGE_RATE=0.12        # Type B 일간 상승률 상한 +12% (과열 late-chase 차단)
TYPE_B_MAX_RET_5M=0.025            # Type B 5분 상승률 상한 +2.5%
TYPE_B_REQUIRE_OB_RATIO=true       # Type B는 오더북 비율 없으면 진입 금지
TYPE_B_MIN_OB_RATIO=1.05           # Type B 최소 매수 우위 오더북
RISK_COIN_MAX_CONCURRENT=2         # 최대 동시 포지션 축소 (3 → 2, 연속 손실 누적 완화)
RISK_COIN_DAILY_LOSS_LIMIT=-5000   # COIN 일 손실 한도 (2026-04-18 -7066원 손실 반영)
RISK_COIN_ALLOCATION_CAP_PCT=0.35  # 1회 진입 최대 35% cash
STRATEGY_COIN_DAILY_CAP=12         # COIN 일 최대 진입 수 축소 (30 → 12)
UPBIT_MARK_HIST_MAX=720            # COIN mark_hist 6시간 보존 (shadow 평가용, 4시간 exit 커버)
COIN_SHADOW_POLL_SEC=60            # COIN shadow ledger 평가 주기 60초
COIN_TYPE_B_ALERT_TRADE_COUNTS=10,20 # Type B shadow milestone alerts (Telegram)

WATCHLIST_KR_MAX_PRICE=50000     # 최대 매수 가능 가격 (원) — 잔고/max_concurrent 기준
