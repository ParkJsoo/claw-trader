# Telegram Control Plane
TG_BOT_TOKEN=
TG_PIN_HASH=          # sha256(PIN)
TG_ALLOWED_USER_ID=
TG_ALLOWED_CHAT_ID=
TG_BOOTSTRAP=0

# Redis
REDIS_URL=redis://:<password>@127.0.0.1:6379/0

# KIS (한국투자증권)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# IBKR
IBKR_HOST=127.0.0.1
IBKR_PORT=4001
IBKR_CLIENT_ID=11
IBKR_ACCOUNT_ID=
IBKR_CURRENCY=USD

# Order Watcher
WATCHER_POLL_SEC=1.0
WATCHER_TTL_CANCEL_SEC=15

# Phase 8 v2 — AI Signal Generator
ANTHROPIC_API_KEY=
GEN_WATCHLIST_KR=005930,000660
GEN_WATCHLIST_US=AAPL,NVDA
GEN_POLL_SEC=60
GEN_MAX_SIZE_CASH_KR=10000
GEN_MAX_SIZE_CASH_US=10
GEN_DAILY_EMIT_CAP=5
GEN_MIN_HIST=20
GEN_COOLDOWN_SEC=300

# Phase 9 — AI Eval Runner
GEN_DAILY_CALL_CAP=2000
GEN_STATUS_LOG_SEC=600
GEN_MD_STALE_SEC=180

# Phase 9.5 — Dual Run
OLLAMA_URL=http://127.0.0.1:11434
QWEN_MODEL=qwen2.5:7b
DUAL_POLL_SEC=120
DUAL_DAILY_CALL_CAP=2000

# News Intelligence Layer
DART_API_KEY=                        # DART OpenAPI 키 (opendart.fss.or.kr)
NEWS_POLL_SEC=1800                   # 수집 주기 (초, 기본 30분)
NEWS_QWEN_CLASSIFY=true              # Qwen 분류 활성화 (Ollama 실행 중일 때)
NEWS_MAX_ITEMS=100                   # 폴링당 최대 저장 건수
NEWS_CLASSIFY_TIMEOUT=25             # Qwen 분류 타임아웃 (초)
# 종목코드:회사명 추가 매핑 (기본값에 없는 종목)
NEWS_KR_NAMES=                       # 예: 000000:종목명,000001:종목명
NEWS_US_NAMES=                       # 예: TICKER:CompanyName
# 매크로 키워드 (쉼표 구분, 비어있으면 내장 기본값 사용)
NEWS_MACRO_KR=                       # 예: 코스피,금리,환율,반도체
NEWS_MACRO_US=                       # 예: fed rate,tariff,S&P 500
